{
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 $HOME/bin/claude_stop_hook.py",
            "timeout": 90,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 $HOME/bin/claude_session_start.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "theme": "auto",
  "agentPushNotifEnabled": true
}
